@namespace frontend.Components.Widgets.Charts
@inject IJSRuntime JS

<div class="mf-widget-card">
    <div class="mf-widget-card__header">
        <i class="bi bi-bar-chart-line me-1"></i> @Title
    </div>
    <div class="mf-widget-card__body">
        <canvas id="@_canvasId" height="110"></canvas>
    </div>
</div>

@code {
    [Parameter] public string Title { get; set; } = "Bar Chart";
    [Parameter] public List<string> Labels { get; set; } = new() { "January", "February", "March", "April", "May", "June" };
    [Parameter] public List<int> Data { get; set; } = new() { 4000, 5200, 6300, 8100, 10200, 15200 };

    private readonly string _canvasId = $"mf-bar-{Guid.NewGuid():N}";

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            await JS.InvokeVoidAsync("mfCharts.renderBarChart", _canvasId, Labels, Data);
        }
    }
}
