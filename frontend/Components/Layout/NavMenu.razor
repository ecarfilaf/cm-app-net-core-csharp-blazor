@using frontend.Services
@inject MenuService MenuSvc

<aside class="app-sidebar">
	<div class="sidebar-brand">
		<i class="bi bi-boxes me-2"></i> CMSYSADMIN
	</div>

    @foreach (var menuSection in _menu.Sections)
    {
        @if (!string.IsNullOrEmpty(menuSection.Title))
        {
            <div class="sidebar-section">@menuSection.Title</div>
        }

        @foreach (var item in menuSection.Items)
        {
            <MenuItemView Item="item" Depth="0" />
        }
    }

    <div class="sidebar-footer">
        <small class="text-muted d-block">Conectado como:</small>
        <strong>frontend</strong>
    </div>
</aside>

@code {
    private MenuConfig _menu = new();

    protected override void OnInitialized()
    {
        _menu = MenuSvc.Load();
    }
}
