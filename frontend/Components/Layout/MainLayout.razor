@inherits LayoutComponentBase

<div class="app-shell">
    <NavMenu />

    <div class="app-content">
        <nav class="navbar navbar-expand app-topbar">
            <div class="container-fluid">
                <button class="btn btn-link text-dark d-md-none" type="button">
                    <i class="bi bi-list fs-4"></i>
                </button>

                <form class="d-none d-md-flex ms-2" role="search">
                    <input class="form-control" type="search" placeholder="Search for..." />
                </form>

                <div class="ms-auto d-flex align-items-center">
                    <i class="bi bi-person-circle fs-4"></i>
                </div>
            </div>
        </nav>

        <main class="app-main">
            @Body
        </main>
    </div>
</div>

<ReconnectModal />
