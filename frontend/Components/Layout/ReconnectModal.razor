<script type="module" src="@Assets["Components/Layout/ReconnectModal.razor.js"]"></script>

<dialog id="components-reconnect-modal" data-nosnippet>
    <div class="components-reconnect-dialog">
        <div class="components-reconnect-icon" aria-hidden="true">
            <div class="components-rejoining-animation">
                <div></div>
                <div></div>
                <div></div>
            </div>
        </div>

        <p class="components-reconnect-visible">
            Se perdió la conexión con el servidor.
        </p>
        <p class="components-reconnect-failed">
            No se pudo reconectar con el servidor.
            <a href="." class="reload">Recargar</a>
        </p>
        <p class="components-reconnect-rejected">
            No se pudo restablecer la sesión con el servidor.
            <a href="." class="reload">Recargar</a>
        </p>

        <button type="button" class="reconnect-retry-button" onclick="location.reload()">
            Reintentar ahora
        </button>
    </div>
</dialog>
